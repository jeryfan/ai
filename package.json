{
  "name": "@jeryfan/ai",
  "version": "0.2.1",
  "description": "Unified LLM API for browser and frontend environments",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "./dist/compat.js",
    "./dist/images.js",
    "./dist/providers/images/register-builtins.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./compat": {
      "types": "./dist/compat.d.ts",
      "import": "./dist/compat.js"
    },
    "./providers/*": {
      "types": "./dist/providers/*.d.ts",
      "import": "./dist/providers/*.js"
    },
    "./api/*": {
      "types": "./dist/api/*.d.ts",
      "import": "./dist/api/*.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json",
    "lint": "oxlint",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "generate-models": "node scripts/generate-models.ts",
    "generate-image-models": "node scripts/generate-image-models.ts",
    "test": "vitest --run",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.91.1",
    "@google/genai": "1.52.0",
    "@mistralai/mistralai": "2.2.6",
    "@opentelemetry/api": "1.9.0",
    "openai": "6.26.0",
    "partial-json": "0.1.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typebox": "1.1.38"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "canvas": "3.2.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "4.1.9"
  },
  "keywords": [
    "ai",
    "llm",
    "unified",
    "api"
  ]
}
